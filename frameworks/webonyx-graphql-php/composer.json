{
    "name": "velocitybench/webonyx-graphql-php",
    "description": "VelocityBench GraphQL implementation using webonyx/graphql-php",
    "type": "project",
    "require": {
        "php": "^8.2",
        "webonyx/graphql-php": "^15.10",
        "overblog/dataloader-php": "^1.0",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "react/promise": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "ramsey/uuid": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "VelocityBench\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VelocityBench\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:4000 -t public"
    }
}
