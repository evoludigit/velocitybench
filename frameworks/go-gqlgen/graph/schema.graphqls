type Query {
  ping: String!
  user(id: ID!): User
  users(limit: Int = 10): [User!]!
  post(id: ID!): Post
  posts(limit: Int = 10): [Post!]!
  comments(limit: Int = 20): [Comment!]!
}

type Mutation {
  updateUser(id: ID!, fullName: String, bio: String): User
  updatePost(id: ID!, title: String, content: String): Post
}

type User {
  id: ID!
  username: String!
  fullName: String
  bio: String
  posts(limit: Int = 50): [Post!]!
  followers(limit: Int = 50): [User!]!
  following(limit: Int = 50): [User!]!
}

type Post {
  id: ID!
  title: String!
  content: String
  author: User!
  comments(limit: Int = 50): [Comment!]!
  createdAt: String!
}

type Comment {
  id: ID!
  content: String!
  author: User
  post: Post
}