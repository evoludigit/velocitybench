# VelocityBench Docker Compose Environment Variables
# Copy this file to .env and customize as needed
# See docker-compose.yml for service definitions

# ============================================================================
# PostgreSQL Configuration
# ============================================================================

# Database name
POSTGRES_DB=velocitybench_benchmark

# Database user
POSTGRES_USER=benchmark

# Database password (INSECURE - for development only)
# Generate secure password: openssl rand -base64 32
POSTGRES_PASSWORD=benchmark123

# PostgreSQL port (host:container)
POSTGRES_PORT=5434

# Data volume size: small (1GB), medium (5GB), large (20GB), xlarge (100GB)
DATA_VOLUME=small

# ============================================================================
# PostgreSQL Performance Tuning
# ============================================================================

# Memory available for shared buffers (default: 8GB)
DB_SHARED_BUFFERS=8GB

# Effective cache size (default: 24GB)
# Should be ~3x shared_buffers
DB_EFFECTIVE_CACHE_SIZE=24GB

# Memory per work operation (default: 64MB)
DB_WORK_MEM=64MB

# Memory for maintenance operations like VACUUM (default: 2GB)
DB_MAINTENANCE_WORK_MEM=2GB

# Max concurrent database connections (default: 300)
DB_MAX_CONNECTIONS=300

# Max worker processes (default: 8)
DB_MAX_WORKER_PROCESSES=8

# Max parallel workers per query gather (default: 4)
DB_MAX_PARALLEL_WORKERS_PER_GATHER=4

# Max parallel workers (default: 8)
DB_MAX_PARALLEL_WORKERS=8

# Max WAL (Write-Ahead Log) size (default: 4GB)
DB_MAX_WAL_SIZE=4GB

# WAL buffers (default: 16MB)
DB_WAL_BUFFERS=16MB

# Random page cost factor for query planner (default: 1.1)
# Lower values = prefer index scans
DB_RANDOM_PAGE_COST=1.1

# ============================================================================
# Framework Configuration
# ============================================================================

# Default environment for frameworks
ENVIRONMENT=development

# Log level for frameworks
LOG_LEVEL=INFO

# Database host (use 'postgres' in docker-compose)
DB_HOST=postgres

# Database port in container
DB_PORT=5432

# ============================================================================
# Python Framework Settings
# ============================================================================

# FastAPI, Flask, Strawberry, Graphene, Ariadne, ASGI-GraphQL

# Minimum database connection pool size (default: 10)
# Controls the minimum number of connections to keep alive in the pool
DB_POOL_MIN_SIZE=10

# Maximum database connection pool size (default: 50)
# Controls the maximum number of concurrent connections
DB_POOL_MAX_SIZE=50

# Prepared statement cache size per connection (default: 100)
# Impacts memory usage and query performance
DB_POOL_STATEMENT_CACHE_SIZE=100

# ============================================================================
# Node.js Framework Settings
# ============================================================================

# Express, Apollo Server, etc.

# Node environment
NODE_ENV=production

# ============================================================================
# Java Framework Settings (Spring Boot)
# ============================================================================

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# ============================================================================
# vLLM Configuration (Blog/Comment Generation)
# ============================================================================

# vLLM server endpoint (for synthetic data generation)
VLLM_SERVER=http://localhost:8000

# Model to use for generation
VLLM_MODEL=meta-llama/Llama-2-7b-hf

# Generation parameters
VLLM_TEMPERATURE=0.7
VLLM_TOP_P=0.9
VLLM_MAX_TOKENS=2000

# ============================================================================
# Monitoring & Observability
# ============================================================================

# Prometheus metrics port
PROMETHEUS_PORT=9090

# Grafana port
GRAFANA_PORT=3000

# ============================================================================
# Development Settings
# ============================================================================

# Debug mode (true/false)
DEBUG=false

# Verbose logging (true/false)
VERBOSE=false

# Dry-run mode for generators (true/false)
DRY_RUN=false

# ============================================================================
# Performance Testing
# ============================================================================

# JMeter test configuration
JMETER_THREADS=100
JMETER_RAMP_UP=60
JMETER_DURATION=300

# ============================================================================
# Notes
# ============================================================================
#
# 1. DATABASE PASSWORD
#    The password in this file is intentionally simple for development.
#    For production, generate a secure password:
#      openssl rand -base64 32
#
# 2. ENVIRONMENT VARIABLES
#    .env file is loaded automatically by docker-compose
#    You can override values on command line:
#      docker-compose -e DB_POOL_MAX=100 up
#
# 3. SERVICES
#    Start all services:
#      docker-compose up
#
#    Start only PostgreSQL:
#      docker-compose up postgres
#
#    Start with Hasura profile:
#      docker-compose --profile hasura up
#
# 4. DATA PERSISTENCE
#    Database data is stored in named volume 'postgres_data'
#    To reset database:
#      docker-compose down -v  # Removes volumes!
#
# 5. NETWORKING
#    All services on same network: velocitybench-benchmark
#    Services can reference each other by name (postgres, fraiseql, etc)
#
# 6. HEALTH CHECKS
#    Services have health checks configured
#    Check status:
#      docker-compose ps
#
# 7. LOGS
#    View service logs:
#      docker-compose logs <service-name>
#      docker-compose logs -f postgres  # Follow mode
#
# 8. RESOURCE LIMITS
#    Adjust PostgreSQL memory settings if your machine has different resources:
#    - Laptop (4GB): DB_SHARED_BUFFERS=1GB, DB_EFFECTIVE_CACHE_SIZE=3GB
#    - Server (64GB): DB_SHARED_BUFFERS=16GB, DB_EFFECTIVE_CACHE_SIZE=48GB
#
